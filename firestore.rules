rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the authenticated user can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Bids — any authenticated user can read; only the shopkeeper who owns it can create/update
    match /bids/{bidId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.shopkeeperId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.shopkeeperId == request.auth.uid
            || request.auth.uid != null); // wholesalers can mark bids completed via order confirm
      allow delete: if request.auth != null
        && resource.data.shopkeeperId == request.auth.uid;
    }

    // Quotations — any authenticated user can read; wholesalers create; shopkeeper can update status
    match /quotations/{quotationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.wholesalerId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.wholesalerId == request.auth.uid
            || resource.data.shopkeeperId == request.auth.uid);
      allow delete: if false;
    }

    // Orders — only participants (shopkeeper or wholesaler) can read/write
    match /orders/{orderId} {
      allow read: if request.auth != null
        && (resource.data.shopkeeperId == request.auth.uid
            || resource.data.wholesalerId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.shopkeeperId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.shopkeeperId == request.auth.uid
            || resource.data.wholesalerId == request.auth.uid);
      allow delete: if false;
    }

    // Notifications — users can only read/write their own notifications
    match /notifications/{notifId} {
      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null; // any auth user can write notif for another user
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
